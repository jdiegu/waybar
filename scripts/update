#!/bin/bash
do_reboot=false
do_not_reboot=false
pacman_args=""

while (( "$#" )); do
  case "$1" in
    -r|--reboot)
      do_reboot=true
      shift
      ;;
    -n|-nr|--no-reboot)
      do_not_reboot=true
      shift
      ;;
    -nc|--noconfirm)
      pacman_args+="--noconfirm "
      shift
      ;;
    *)
      echo "Usage: $0 [-r|--reboot] [-n|-nr|--no-reboot] [-nc|--noconfirm]"
      echo "Unknown option \"$1\""
      exit 1
      ;;
  esac
done

pacman $pacman_args -Syu

i_dont_need_those=(
    "/usr/share/applications/lstopo.desktop"
    "/usr/share/applications/electron37.desktop"
    "/usr/share/applications/thunar-settings.desktop"
    "/usr/share/applications/thunar-bulk-rename.desktop"
    "/usr/share/applications/qt6ct.desktop"
    "/usr/share/applications/assistant.desktop"
    "/usr/share/applications/qdbusviewer.desktop"
    "/usr/share/applications/linguist.desktop"
    "/usr/share/applications/designer.desktop"
    "/usr/share/applications/xgps.desktop"
    "/usr/share/applications/xgpsspeed.desktop"
    "/usr/share/applications/qvidcap.desktop"
    "/usr/share/applications/qv4l2.desktop"
    "/usr/share/applications/rofi.desktop"
    "/usr/share/applications/rofi-theme-selector.desktop"
    "/usr/share/applications/org.flameshot.Flameshot.desktop"
    "/usr/share/applications/cmake-gui.desktop"
    "/usr/share/applications/avahi-discover.desktop"
    "/usr/share/applications/bssh.desktop"
    "/usr/share/applications/bvnc.desktop"
    "/usr/share/applications/gammastep-indicator.desktop"
    "/usr/share/applications/kvantummanager.desktop"
)

for path in "${i_dont_need_those[@]}"; do
    if [[ -e "$path" ]]; then
        rm -rf "$path"
        echo "Removed trash: $path"
    fi
done

orphaned_packages=$(pacman -Qdtq)

if [[ -n "$orphaned_packages" ]]; then
    echo "Removing orphaned packages..."
    pacman $pacman_args -Rns $orphaned_packages
fi

if [[ "$do_reboot" = true ]]; then
    reboot
elif [[ "$do_not_reboot" = false ]]; then
    read -r -p "Reboot? [Y/n] " response
    if ! [[ "$response" =~ ^([nN][oO]|[nN])$ ]]; then
        reboot
    fi
fi
